          <mxGeometry x="1060" y="420" width="300" height="95" as="geometry" />
        </mxCell>
        <mxCell id="prompt_template" value="외부/내장 Prompt Template&#xa;{{designBrief}} 치환" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#E7A94B;fontSize=14;fontStyle=1;arcSize=8;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="560" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="llm_request" value="LLM Request&#xa;imagePrompt / layoutMapping / mdComplianceMap 생성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF3FF;strokeColor=#4F8FD9;fontSize=15;fontStyle=1;arcSize=8;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="700" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sectionInputs" value="sectionInputs&#xa;출처: B섹션 프로모션 빌더&#xa;역할: Temp.4 화면에 실제 노출될 섹션별 컨텐츠&#xa;&#xa;Header, Hero Banner, Step Bar, Content CTA, Image Text Row, Terms/Footer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9F0;strokeColor=#E7A94B;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="simpleBrief" value="simpleBrief&#xa;출처: B섹션 간편 입력&#xa;역할: 프로모션 의도와 캠페인 맥락&#xa;&#xa;주요 혜택, 유도 행동, 대상 고객, 보조 메시지, 캠페인 톤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9F0;strokeColor=#E7A94B;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="requiredContent" value="requiredContent&#xa;출처: promo 기본 필드 + fallback&#xa;역할: 반드시 보여야 하는 핵심 텍스트 계약&#xa;&#xa;promoTitle, leadText, CTA, subline, alpha/legal, terms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9F0;strokeColor=#E7A94B;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="120" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="designStyle" value="designStyle&#xa;출처: B섹션 스타일 조정 결과&#xa;역할: 색상/폰트/스타일 제약&#xa;&#xa;finalStyle 값이 전달됨. 단, MD 레이아웃 철학을 대체하면 안 됨." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F4FF;strokeColor=#8A6EDB;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="120" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="mdConceptSummary" value="mdConceptSummary&#xa;출처: 선택된 Design MD 분석 결과&#xa;역할: MD의 핵심 디자인 방향 요약&#xa;&#xa;designConcept.summary 또는 conceptJson.brandConcept" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5FAFF;strokeColor=#4F8FD9;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="650" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="mdPromptContext" value="mdPromptContext&#xa;출처: Design MD promptContext&#xa;역할: 이미지 생성 프롬프트에 반영할 MD 문맥&#xa;&#xa;designPromptContext 또는 designConcept.promptContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5FAFF;strokeColor=#4F8FD9;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="650" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="mdConceptJson" value="mdConceptJson&#xa;출처: Design MD 구조화 분석 JSON&#xa;역할: 레이아웃 철학, 무드, 구성, 컴포넌트 언어, 효과, 반경, dos/donts 근거&#xa;&#xa;designConcept.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5FAFF;strokeColor=#4F8FD9;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="650" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="mdSummary" value="mdSummary&#xa;출처: 선택된 Design MD 요약 데이터&#xa;역할: 문서 기반 보조 컨텍스트&#xa;&#xa;headings, excerpts, colors, typography 등 요약 정보" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5FAFF;strokeColor=#4F8FD9;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="850" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="gap" value="현재 검증 한계&#xa;이 값들은 designBrief에 유입되지만, 각 값이 최종 이미지에 얼마나 반영됐는지 별도 점수/coverage가 없음" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0F0;strokeColor=#DD6B6B;fontSize=14;fontStyle=1;arcSize=8;spacing=12;" vertex="1" parent="1">
